{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "customConditions": ["node"],
    "lib": ["ES2024", "DOM"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "strict": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules"]
}
